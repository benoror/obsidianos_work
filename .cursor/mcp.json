{
  "mcpServers": {
    "qmd": {
      "command": "npx",
      "args": ["qmd", "mcp"]
    },
    "google-workspace": {
      "command": "sh",
      "args": [
        "-c",
        ". ./.env && exec uvx workspace-mcp --tools docs drive calendar gmail"
      ],
      "env": {
        "OAUTHLIB_INSECURE_TRANSPORT": "1"
      }
    }
  }
}
